# Do not auto-install peer dependencies.
#
# @chatbox/core declares react, react-dom, and styled-components as peer deps
# — they must be provided by the consumer, NOT installed into this package's
# own node_modules. When npm 7+ auto-installs peers, those nested copies become
# visible to consumers that import @chatbox/core via a `file:` symlink (e.g.,
# tethysapp-tethys_dash). Node's require resolution then finds @chatbox/core's
# *nested* react before walking up to the consumer's root react, producing two
# React instances and breaking hooks at runtime with:
#
#   TypeError: Cannot read properties of null (reading 'useState')
#
# Setting `legacy-peer-deps=true` restores npm 6's behavior: peer deps are
# validated but not installed automatically. Dev-only tooling that needs React
# (e.g., for vite build, type checks) should add it as a devDependency
# explicitly if the need arises.
legacy-peer-deps=true
